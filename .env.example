# Endpoint del proyecto de Azure AI Foundry
# Formato: https://<recurso>.services.ai.azure.com/api/projects/<proyecto>
PROJECT_ENDPOINT=

# Nombre del despliegue de modelo de chat en el proyecto
MODEL_DEPLOYMENT_NAME=gpt-4.1

# Nombre del agente en Foundry
AGENT_NAME=asistente-historias-usuario

# Nombre de la Function App (HTTP triggers para las tools)
FUNCTION_APP_NAME=func-userstories-agent-001

# Carpeta local que actúa de repositorio de documentos en el MVP
# (en producción: SharePoint / Azure DevOps Wiki / Blob Storage)
REPOSITORIO_DIR=

# --- Infra (para deploy.sh) ---
RESOURCE_GROUP=Agentic
LOCATION=swedencentral
